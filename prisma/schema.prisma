generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int         @id @default(autoincrement()) @map("id")
  name             String         @db.VarChar(255) @map("name")
  email            String         @unique(map: "users_email_unique") @db.VarChar(255) @map("email")
  avatar           String?        @db.VarChar(255) @map("avatar")
  emailVerifiedAt  DateTime?      @db.Timestamp(0) @map("email_verified_at")
  password         String         @db.VarChar(255) @map("password")
  rememberToken    String?        @db.VarChar(100) @map("remember_token")
  createdAt        DateTime       @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt        DateTime       @updatedAt @db.Timestamp(0) @map("updated_at")

  ownedGroups      Group[]        @relation("GroupOwner")
  groupUsers       GroupUser[]
  conversations    UserConversation[]
  messagesSent     Message[]      @relation("MessageSender")
  messagesReceived Message[]      @relation("MessageReceiver")

  @@map("users")
}

model Group {
  id            Int         @id @default(autoincrement()) @map("id")
  name          String         @db.VarChar(255) @map("name")
  description   String?        @map("description")
  avatar        String?        @db.VarChar(255) @map("avatar")
  isPrivate     Boolean        @default(false) @map("is_private")
  ownerId       Int         @map("owner_id")
  createdAt     DateTime       @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt     DateTime       @updatedAt @db.Timestamp(0) @map("updated_at")

  owner         User           @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  groupUsers    GroupUser[]

  @@map("groups")
}

model GroupUser {
  id                  Int    @id @default(autoincrement()) @map("id")
  groupId             Int    @map("group_id")
  userId              Int    @map("user_id")
  role                String    @default("member") @db.VarChar(255) @map("role")
  unreadMessagesCount Int       @default(0) @map("unread_messages_count")
  blockedAt           DateTime? @db.Timestamp(0) @map("blocked_at")
  createdAt           DateTime  @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt           DateTime  @updatedAt @db.Timestamp(0) @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_user")
}

model Conversation {
  id                Int             @id @default(autoincrement()) @map("id")
  groupId           Int?            @map("group_id")
  lastMessageId     Int?            @map("last_message_id") @unique
  createdAt         DateTime           @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt         DateTime           @updatedAt @db.Timestamp(0) @map("updated_at")

  group             Group?             @relation(fields: [groupId], references: [id], onDelete: NoAction)
  lastMessage       Message?           @relation("ConversationLastMessage", fields: [lastMessageId], references: [id], onDelete: NoAction)
  messages          Message[]          @relation("ConversationMessages")
  userConversations UserConversation[]

  @@map("conversations")
}

model UserConversation {
  id                  Int        @id @default(autoincrement()) @map("id")
  userId              Int        @map("user_id")
  conversationId      Int        @map("conversation_id")
  unreadMessagesCount Int           @default(0) @map("unread_messages_count")
  createdAt           DateTime      @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt           DateTime      @updatedAt @db.Timestamp(0) @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("user_conversation")
}

model Message {
  id             Int         @id @default(autoincrement()) @map("id")
  content        String?        @map("message")
  senderId       Int         @map("sender_id")
  receiverId     Int?        @map("receiver_id")
  conversationId Int         @map("conversation_id")
  createdAt      DateTime       @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt      DateTime       @updatedAt @db.Timestamp(0) @map("updated_at")

  sender         User           @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User?          @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: NoAction)
  conversation   Conversation?  @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: NoAction)
  lastMessageFor Conversation?  @relation("ConversationLastMessage")
  attachments    MessageAttachment[]

  @@map("messages")
}

model MessageAttachment {
  id         Int    @id @default(autoincrement()) @map("id")
  messageId  Int    @map("message_id")
  name       String    @db.VarChar(255) @map("name")
  path       String    @db.VarChar(1024) @map("path")
  mime       String    @db.VarChar(225) @map("mime")
  size       Int       @map("size")
  createdAt  DateTime  @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt  DateTime  @updatedAt @db.Timestamp(0) @map("updated_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}
